# Upstash Developer API — https://console.upstash.com (Account > Developer API)
UPSTASH_EMAIL=
UPSTASH_API_KEY=

# OpenRouter (powers the AI command bar) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional model override for the AI planner (must support JSON output).
# Default is openai/gpt-5-nano. Others: openai/gpt-5.2, google/gemini-2.5-flash.
OPENROUTER_MODEL=openai/gpt-5-nano

# QStash — https://console.upstash.com/qstash (enables the QStash screen)
QSTASH_TOKEN=
