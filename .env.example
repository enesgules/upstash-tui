# Upstash Developer API — https://console.upstash.com (Account > Developer API)
UPSTASH_EMAIL=
UPSTASH_API_KEY=

# OpenRouter (powers the AI command bar) — https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional model override for the AI planner (must support structured outputs).
# Default anthropic/claude-opus-4.8. Cheaper: openai/gpt-5-nano, google/gemini-2.5-flash.
OPENROUTER_MODEL=anthropic/claude-opus-4.8

# QStash — https://console.upstash.com/qstash (enables the QStash screen)
QSTASH_TOKEN=
